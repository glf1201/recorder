<Window x:Class="RecorderApp.Views.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入退出密码"
        Width="320"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock FontSize="14" FontWeight="SemiBold" Text="请输入退出密码" />
    <PasswordBox x:Name="PasswordInput" Grid.Row="1" Height="40" Margin="0,12,0,20" FontWeight="Normal" />
    <StackPanel Grid.Row="2" Margin="0,6,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
      <Button Width="90" Height="42" Padding="16,0" Margin="0,0,10,0" Click="CancelButton_Click" Content="取消" Style="{StaticResource GhostButtonStyle}" />
      <Button Width="90" Height="42" Padding="16,0" Click="OkButton_Click" Content="确定" IsDefault="True" Style="{StaticResource PrimaryActionButtonStyle}" />
    </StackPanel>
  </Grid>
</Window>
